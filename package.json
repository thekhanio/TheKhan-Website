{
  "name": "thekhan-agency",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:green": "VITE_ACCENT=green vite",
    "dev:oxblood": "VITE_ACCENT=oxblood vite",
    "dev:blue": "VITE_ACCENT=blue vite",
    "build": "tsc -b && vite build",
    "build:green": "VITE_ACCENT=green tsc -b && VITE_ACCENT=green vite build",
    "build:oxblood": "VITE_ACCENT=oxblood tsc -b && VITE_ACCENT=oxblood vite build",
    "build:blue": "VITE_ACCENT=blue tsc -b && VITE_ACCENT=blue vite build",
    "preview": "vite preview",
    "deploy:dev-green": "bun run build:green && wrangler deploy --env dev-green",
    "deploy:dev-oxblood": "bun run build:oxblood && wrangler deploy --env dev-oxblood",
    "deploy:dev-blue": "bun run build:blue && wrangler deploy --env dev-blue"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.36.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.62.0"
  }
}
